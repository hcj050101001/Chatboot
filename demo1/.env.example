# 对话模型（OpenAI Chat Completions 兼容接口）
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=请填写对话模型密钥
LLM_MODEL=请填写可用模型名称

# DashScope 文本向量模型（知识库检索）
DASHSCOPE_API_KEY=请填写阿里云百炼API密钥
EL_MODEL=text-embedding-v4

# MySQL ERP 数据库；MySQL 未配置时，知识库问答仍可运行
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=请填写本机MySQL密码
DB_NAME=erp_db

# 零件图片检测服务
DETECT_API_URL=http://47.104.167.34:9900/api/detect

# 设为0可禁止启动时自动打开浏览器，默认自动打开
OPEN_BROWSER=1
